{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/webmaster442/EngineerCalc/docmodel.schema.json",
  "title": "Docmodel",
  "description": "Schema for function documentation model",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "description": "Single function documentation",
    "required": [
      "functionName",
      "description",
      "examples",
      "arguments"
    ],
    "properties": {
      "functionName": {
        "type": "string",
        "description": "The name of the function"
      },
      "description": {
        "type": "string",
        "description": "Function description",
        "minLength": 1
      },
      "examples": {
        "type": "array",
        "description": "Examples of function usage",
        "items": {
          "type": "string"
        }
      },
      "arguments": {
        "type": "array",
        "description": "Function arguments",
        "items": {
          "type": "object",
          "description": "Represents a function argument",
          "required": [
            "name",
            "description"
          ],
          "properties": {
            "name": {
              "type": "string",
              "description": "The argument name"
            },
            "description": {
              "type": "string",
              "description": "The argument description"
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "additionalProperties": false
}
