{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/webmaster442/EngineerCalc/docmodel.schema.json",
  "title": "Docmodel",
  "description": "Schema for function documentation model",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "const": "docmodel.schema.json",
      "description": "Schema identifier"
    },
    "functions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "summary",
          "parameters",
          "examples"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Function name"
          },
          "summary": {
            "type": "string",
            "description": "Brief summary of the function",
            "minLength": 1
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Parameter name"
                },
                "supportedTypes": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Parameter types, separated by | for multiple types"
                },
                "description": {
                  "type": "string",
                  "description": "Description of the parameter"
                }
              },
              "required": [
                "name",
                "supportedTypes",
                "description"
              ],
              "additionalProperties": false
            }
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [ "functions" ]
}